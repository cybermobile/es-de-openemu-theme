<theme>
    <!-- 16:9 Layout (Primary / Reference layout) -->
    <!-- All positions in theme.xml are tuned for 16:9 -->
    <!-- This file is intentionally minimal - overrides only if needed -->

    <view name="system">
        <carousel name="systemCarousel">
            <pos>0.5 0.52</pos>
            <size>1 0.48</size>
            <maxItemCount>3</maxItemCount>
            <itemSize>0.28 0.7</itemSize>
        </carousel>
    </view>

    <variant name="grid-cover">
        <view name="gamelist">
            <grid name="gameGrid">
                <itemSize>0.155 0.28</itemSize>
            </grid>
        </view>
    </variant>

    <variant name="grid-screenshot">
        <view name="gamelist">
            <grid name="gameGrid">
                <itemSize>0.22 0.2</itemSize>
            </grid>
        </view>
    </variant>
</theme>
